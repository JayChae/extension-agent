ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# 모델 선택(선택). 비우면 기본 anthropic:claude-sonnet-4-6. 예: openai:gpt-4.1
AGENT_MODEL=
# 허용 도메인 allowlist(선택, 쉼표 구분). 비우면 기본 scourt.go.kr. 범용 확장 시 추가(§11·§15-5)
ALLOWED_DOMAINS=
# 🔐 자격증명 금고 마스터키(Fernet). 비우면 backend/vault/master.key를 자동 생성·재사용(설정 불필요).
# 운영에서 키를 직접 주입하려면 여기에 넣으세요(있으면 우선). 등록은 사이드패널 '자격증명' 카드에서(§11)
VAULT_KEY=
